# Jamly public frontend variables.
# These are safe to expose in the browser, but real values should still live
# in Netlify environment variables, Docker Compose environment, or a local .env file.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Docker Compose local port. Change only if port 3000 is already used.
APP_PORT=3000
