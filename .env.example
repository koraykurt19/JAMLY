# Jamly public frontend variables.
# Leave these empty for demo mode.
# For live Supabase mode, paste the Project URL and publishable/anon public key from:
# Supabase Dashboard -> Project Settings -> API
# Never put sb_secret/service_role keys in frontend env files.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Docker Compose local port. Change only if port 3000 is already used.
APP_PORT=3000
